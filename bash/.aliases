# Set my aliases

# Elgato keylights
alias l="elgato-key-light toggle"                                                                                                                # Toggle key light
alias lon="elgato-key-light on"                                                                                                                  # Turn on key light
alias loff="elgato-key-light off"                                                                                                                # Turn off key light

# Git
alias g="git"                                                                                                                                    # Git shorthand
alias gcl="git clone"                                                                                                                            # Clone repository
alias gck="git checkout"                                                                                                                         # Switch branch or restore file
alias gcb="git checkout -b"                                                                                                                      # Create and switch to new branch
alias gst="git status"                                                                                                                           # Show working tree status
alias gdf="git diff"                                                                                                                             # Show unstaged changes
alias gdfs="git diff --staged"                                                                                                                   # Show staged changes
alias gad="git add"                                                                                                                              # Stage files
alias gada="git add --all"                                                                                                                       # Stage all files
alias grm="git rm"                                                                                                                               # Remove files from index
alias gcm="git commit"                                                                                                                           # Create commit
alias gcmm="git commit -m"                                                                                                                       # Commit with message
alias gcma="git commit --amend"                                                                                                                  # Amend last commit
alias gcman="git commit --amend --no-edit"                                                                                                       # Amend last commit without editing message
alias gpl="git pull"                                                                                                                             # Pull from remote
alias gplr="git pull --rebase"                                                                                                                   # Pull with rebase
alias gps="git push"                                                                                                                             # Push to remote
alias gpsf="git push --force-with-lease"                                                                                                         # Safe force push
alias grb="git rebase"                                                                                                                           # Rebase
alias grbi="git rebase -i"                                                                                                                       # Interactive rebase
alias grbm="git rebase origin/main"                                                                                                              # Rebase onto main
alias grs="git reset"                                                                                                                            # Reset commits or staging
alias grsh="git reset --hard"                                                                                                                    # Discard all local changes
alias gsh="git stash"                                                                                                                            # Stash changes
alias gshl="git stash list"                                                                                                                      # List stashes
alias gshp="git stash pop"                                                                                                                       # Pop and remove last stash
alias gsha="git stash apply"                                                                                                                     # Apply last stash without removing
alias gshd="git stash drop"                                                                                                                      # Drop last stash
alias gb="git branch -l"                                                                                                                         # List branches
alias gbl="git branch -l"                                                                                                                        # List branches
alias gbd="git branch -d"                                                                                                                        # Delete branch (safe)
alias gbD="git branch -D"                                                                                                                        # Force delete branch
alias glg="git log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit"     # Visual log with graph
alias gm="git merge"                                                                                                                             # Merge branch
alias gcp="git cherry-pick"                                                                                                                      # Cherry-pick commit
alias gft="git fetch"                                                                                                                            # Fetch from remote
alias gfta="git fetch --all"                                                                                                                     # Fetch from all remotes
alias grmt="git remote -v"                                                                                                                       # List remotes
alias gcf="git config --list"                                                                                                                    # List git config
alias gwt="git worktree"                                                                                                                         # Manage worktrees
alias gwtl="git worktree list"                                                                                                                   # List worktrees
alias gwta="git worktree add"                                                                                                                    # Add worktree (existing branch)
alias gwtab="git worktree add -b"                                                                                                                # Add worktree with new branch
alias gwtrm="git worktree remove"                                                                                                                # Remove worktree
alias gwtp="git worktree prune"                                                                                                                  # Prune stale worktrees
alias gwtm="git worktree move"                                                                                                                   # Move worktree
alias gwtlk="git worktree lock"                                                                                                                  # Lock worktree
alias gwtulk="git worktree unlock"                                                                                                               # Unlock worktree

# Rails
alias rce="bin/rails credentials:edit"                  # Edit master credentials
alias rced="bin/rails credentials:edit -e development"  # Edit development credentials
alias rcep="bin/rails credentials:edit -e production"   # Edit production credentials
alias rcs="bin/rails credentials:show"                  # Show master credentials
alias rcsd="bin/rails credentials:show -e development"  # Show development credentials
alias rcsp="bin/rails credentials:show -e production"   # Show production credentials

alias rgmi="bin/rails generate migration"               # Generate migration
alias rdmi="bin/rails destroy migration"                # Destroy migration
alias rgmd="bin/rails generate model"                   # Generate model
alias rdmd="bin/rails destroy model"                    # Destroy model
alias rgct="bin/rails generate controller"              # Generate controller
alias rdct="bin/rails destroy controller"               # Destroy controller
alias rgsc="bin/rails generate scaffold_controller"     # Generate scaffold controller
alias rdsc="bin/rails destroy scaffold_controller"      # Destroy scaffold controller
alias rgjb="bin/rails generate job"                     # Generate job
alias rdjb="bin/rails destroy job"                      # Destroy job
alias rghp="bin/rails generate helper"                  # Generate helper
alias rdhp="bin/rails destroy helper"                   # Destroy helper
alias rgat="bin/rails generate authentication"          # Generate authentication
alias rdat="bin/rails destroy authentication"           # Destroy authentication

alias rc="bin/rails console"                            # Open Rails console
alias rr="bin/rails routes"                             # List routes

alias rt="RUBYOPT='-W:no-deprecated' bin/rails test"              # Run all tests
alias rtm="RUBYOPT='-W:no-deprecated' bin/rails test:models"      # Run model tests
alias rtc="RUBYOPT='-W:no-deprecated' bin/rails test:controllers" # Run controller tests
alias rtj="RUBYOPT='-W:no-deprecated' bin/rails test:jobs"        # Run job tests
alias rth="RUBYOPT='-W:no-deprecated' bin/rails test:helpers"     # Run helper tests
alias rts="RUBYOPT='-W:no-deprecated' bin/rails test:system"      # Run system tests
alias rta="RUBYOPT='-W:no-deprecated' bin/rails test:all"         # Run all tests

alias rl="bin/rubocop"                                  # Lint with Rubocop
alias rlf="bin/rubocop -a"                              # Auto-fix with Rubocop (safe)
alias rla="bin/rubocop -A"                              # Auto-fix with Rubocop (aggressive)

alias rbk="bin/brakeman --no-pager"                     # Security analysis

alias bia="bin/importmap audit"                         # Audit importmap vulnerabilities

alias rdbst="bin/rails db:setup"                        # Full DB setup (create + migrate + seed)
alias rdbcr="bin/rails db:create"                       # Create database
alias rdbmi="bin/rails db:migrate"                      # Run pending migrations
alias rdbrb="bin/rails db:rollback"                     # Rollback last migration
alias rdbsd="bin/rails db:seed"                         # Seed database
alias rdbsdr="bin/rails db:seed:replant"                # Truncate and re-seed database

alias fsd="bundle exec foreman start -f Procfile.dev"   # Start dev server
alias fsp="bundle exec foreman start -f Procfile"       # Start production server

# Bundle
alias ba="bundle add"                                   # Add gem to Gemfile
alias bi="bundle install"                               # Install gems from Gemfile
alias be="bundle exec"                                  # Run command in bundle context

# Kamal
alias kamal='docker run -it --rm -v "${PWD}:/workdir" -v "${HOME}/.ssh/id_rsa:/root/.ssh/id_rsa" -v /var/run/docker.sock:/var/run/docker.sock -e KAMAL_REGISTRY_PASSWORD=$(env | grep "^KAMAL_" | cut -d '=' -f2) ghcr.io/basecamp/kamal:latest' # Run Kamal via Docker
alias kd="bin/kamal deploy"                             # Deploy
alias kl="bin/kamal logs"                               # View logs
alias klf="bin/kamal logs --follow"                     # Follow logs in real time
alias klt="bin/kamal logs --tail"                       # View last log lines
alias kex="bin/kamal exec"                              # Execute remote command
alias kexh="bin/kamal exec --help"                      # Exec help
alias kc="bin/kamal console"                            # Open remote console
alias ks="bin/kamal shell"                              # Open remote shell

# pnpm
alias p="pnpm"                                          # pnpm shorthand
alias pi="pnpm install"                                 # Install dependencies
alias pa="pnpm add"                                     # Add package
alias pad="pnpm add -D"                                 # Add package as devDependency
alias prm="pnpm remove"                                 # Remove package
alias px="pnpm dlx"                                     # Execute package without installing

# Dev
alias pd="pnpm dev"                                     # Start dev server
alias pdh="pnpm dev:https"                              # Start dev server with HTTPS
alias pdhl="pnpm dev:https > /tmp/development.log 2>&1" # Start HTTPS dev server with log to /tmp
alias pb="pnpm build"                                   # Build project
alias pl="pnpm lint"                                    # Lint
alias pf="pnpm format"                                  # Format code
alias pv="pnpm verify"                                  # Verify code (lint + types + tests)
alias pct="pnpm check-types"                            # Check TypeScript types

# Tests
alias pt="pnpm test"                                    # Run tests
alias ptw="pnpm test:watch"                             # Run tests in watch mode
alias ptu="pnpm test:unit"                              # Run unit tests
alias pti="pnpm test:integration"                       # Run integration tests
alias pte="pnpm test:e2e"                               # Run end-to-end tests
alias ptc="pnpm test:coverage"                          # Run tests with coverage
alias pta="pnpm test:all"                               # Run all tests

# Database - Drizzle
alias pdbg="pnpm db:generate"                           # Generate migration (Drizzle)
alias pdbm="pnpm db:migrate"                            # Run migrations (Drizzle)
alias pdbs="pnpm db:status"                             # Show migration status (Drizzle)

# Docker
alias pdu="pnpm docker:up"                              # Start Docker containers
alias pdd="pnpm docker:down"                            # Stop Docker containers
alias pdl="pnpm docker:logs"                            # View Docker container logs

# Claude Code
alias c="claude"                                        # Interactive session
alias cy="claude --dangerously-skip-permissions"        # Yolo mode (skip permission prompts)
alias cc="claude -c"                                    # Continue last conversation
alias ccy="claude -c --dangerously-skip-permissions"    # Continue last conversation (yolo)
alias cr="claude -r"                                    # Resume conversation by ID
alias cpt="claude -p"                                   # Print mode (non-interactive)
alias cup="claude update"                               # Update Claude Code

# OpenCode
alias oc="opencode"                                     # Interactive TUI
alias occ="opencode -c"                                 # Continue last session
alias ocs="opencode -s"                                 # Resume session by ID
alias ocr="opencode run"                                # Run with message (non-interactive)
alias ocw="opencode web"                                # Web interface
alias ocp="opencode pr"                                 # Fetch PR and run
alias ocst="opencode stats"                             # Token usage and costs
alias ocup="opencode upgrade"                           # Update OpenCode

# Neovim
alias n="nvim"                                          # Open Neovim
alias n.="nvim ."                                       # Open Neovim in current directory

# Lazygit
alias lzg="lazygit"                                     # Visual git interface

# Lazydocker
alias lzd="lazydocker"                                  # Visual Docker interface

# Shell
alias scp="scp -O"                                      # Copy files via SSH (legacy mode)

# Navigation
alias h="cd ~"                                          # Go to home directory
alias ..="cd .."                                        # Go up one level
alias ...="cd ../.."                                    # Go up two levels

# Others
alias o="xdg-open"                                      # Open file or URL with default app
alias m="rmpc"                                          # Music player control
