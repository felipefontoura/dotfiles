{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "agent": {
    "build": {
      "model": "anthropic/claude-opus-4-6"
    },
    "plan": {
      "model": "anthropic/claude-opus-4-6"
    }
  },
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "enabled": false
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false
    }
  },
  "permission": {
    "read": "allow",
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "skill": "allow",
    "task": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "codesearch": "allow",
    "bash": {
      "*": "ask",
      "bash *": "allow",
      "sh *": "allow",
      "source *": "allow",
      "cd *": "allow",
      "ls *": "allow",
      "tree *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "find *": "allow",
      "wc *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "df *": "allow",
      "realpath *": "allow",
      "readlink *": "allow",
      "which *": "allow",
      "type *": "allow",
      "dirname *": "allow",
      "basename *": "allow",
      "pwd *": "allow",
      "env *": "allow",
      "printenv *": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "date *": "allow",
      "w *": "allow",
      "alias *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "diff *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "tr *": "allow",
      "jq *": "allow",
      "yq *": "allow",
      "sed *": "allow",
      "awk *": "allow",
      "xargs *": "allow",
      "tee *": "allow",
      "mkdir *": "allow",
      "rm *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "touch *": "allow",
      "chmod *": "allow",
      "ln *": "allow",
      "tar *": "allow",
      "unzip *": "allow",
      "zip *": "allow",
      "stow *": "allow",
      "git *": "allow",
      "gh *": "allow",
      "node *": "allow",
      "pnpm *": "allow",
      "npx *": "allow",
      "tsx *": "allow",
      "tsc *": "allow",
      "turbo run *": "allow",
      "ruby *": "allow",
      "bundle *": "allow",
      "gem list *": "allow",
      "gem info *": "allow",
      "bin/rails *": "allow",
      "bin/rake *": "allow",
      "bin/rubocop *": "allow",
      "bin/brakeman *": "allow",
      "bin/importmap *": "allow",
      "python3 *": "allow",
      "pip3 install *": "allow",
      "docker *": "allow",
      "kubectl *": "allow",
      "helm *": "allow",
      "doctl *": "allow",
      "terraform *": "allow",
      "openssl *": "allow",
      "psql *": "allow",
      "pg_isready *": "allow",
      "curl *": "allow",
      "wget *": "allow",
      "dig *": "allow",
      "host *": "allow",
      "nslookup *": "allow",
      "resolvectl query *": "allow",
      "ss *": "allow",
      "lsof *": "allow",
      "netstat *": "allow",
      "swapon *": "allow",
      "fuser -k *": "allow",
      "kill *": "allow",
      "pkill *": "allow",
      "pgrep *": "allow",
      "act push *": "allow",
      "convert *": "allow",
      "identify *": "allow",
      "qrencode *": "allow"
    }
  }
}
